   "outputs": [],
   "source": [
    "# Cell 8 — TEST QILISH\n",
    "# Qaysi pairlarni test qilmoqchisiz? ID'larni belgilang.\n",
    "# Hammasi uchun: TEST_IDS = None\n",
    "TEST_IDS = [\"C04\", \"C05\", \"C07\", \"C08\"]  # Lower + Overall uchun\n",
    "# TEST_IDS = None  # Barcha C01-C08\n",
    "\n",
    "LOOKZI_ROOT = \"/content/Lookzi\"\n",
    "OUTPUT_DIR = \"/content/drive/MyDrive/Lookzi/idm_test_results\"\n",
    "os.makedirs(OUTPUT_DIR, exist_ok=True)\n",
    "\n",
    "with open(f\"{LOOKZI_ROOT}/benchmark/catalog_pairs.json\") as f:\n",
    "    pairs = json.load(f)[\"pairs\"]\n",
    "\n",
    "if TEST_IDS:\n",
    "    pairs = [p for p in pairs if p[\"id\"] in TEST_IDS]\n",
    "\n",
    "print(f\"{len(pairs)} ta test qilinadi.\\n\")\n",
    "\n",
    "results = {}\n",
    "for pair in pairs:\n",
    "    pid = pair[\"id\"]\n",
    "    tag = pair[\"tag\"]\n",
    "    person_path  = f\"{LOOKZI_ROOT}/{pair['person']}\"\n",
    "    garment_path = f\"{LOOKZI_ROOT}/{pair['garment']}\"\n",
    "    cloth_type   = pair[\"cloth_type\"]\n",
    "\n",
    "    print(f\"━━━ {pid} ({cloth_type}) — {tag}\")\n",
    "\n",
    "    # IDM-VTON run\n",
    "    print(\"  IDM-VTON ishlamoqda...\")\n",
    "    torch.cuda.empty_cache()\n",
    "    idm_result = run_idm_vton(person_path, garment_path, cloth_type)\n",
    "\n",
    "    # Natijani saqlash\n",
    "    if idm_result:\n",
    "        save_path = f\"{OUTPUT_DIR}/{pid}_idm.png\"\n",
    "        idm_result.save(save_path)\n",
    "        results[pid] = {\"status\": \"ok\", \"path\": save_path}\n",
    "        print(f\"  Saqlandi: {save_path}\")\n",
    "    else:\n",
    "        results[pid] = {\"status\": \"failed\"}\n",
    "        print(\"  FAILED.\")\n",
    "\n",
    "    # CatVTON natijasi (agar avval saqlab qo'yilgan bo'lsa)\n",
    "    catvton_path = f\"{OUTPUT_DIR}/{pid}_catvton.png\"  # yo'q bo'lsa None\n",
    "\n",
    "    # Ko'rsatish\n",
    "    show_comparison(person_path, garment_path, catvton_path, idm_result, pid, tag)\n",
    "\n",
    "print(\"\\nBarcha testlar tugadi.\")\n",
    "print(\"Natijalar:\", results)"
   ]
  },
  {
