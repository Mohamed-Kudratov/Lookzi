   "source": [
    "# Cell 6 — IDM-VTON pipeline yuklash\n",
    "import sys\n",
    "sys.path.insert(0, '/content/IDM-VTON')\n",
    "\n",
    "import torch\n",
    "from PIL import Image\n",
    "\n",
    "# IDM-VTON Gradio demo'sining pipeline'ini ishlatamiz\n",
    "# Bu eng sodda yo'l — barcha preprocessing ichida\n",
    "try:\n",
    "    from gradio_demo.app import start_tryon\n",
    "    print(\"IDM-VTON pipeline yuklandi (gradio_demo.app).\")\n",
    "    USE_GRADIO_APP = True\n",
    "except Exception as e:\n",
    "    print(f\"gradio_demo.app yuklanmadi: {e}\")\n",
    "    USE_GRADIO_APP = False\n",
    "\n",
    "print(f\"CUDA xotira: {torch.cuda.memory_allocated()/1e9:.1f}GB / {torch.cuda.get_device_properties(0).total_memory/1e9:.1f}GB\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell-07",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cell 7 — IDM-VTON inference funksiyasi\n",
    "import os\n",
    "import json\n",
    "import torch\n",
    "from PIL import Image\n",
    "import numpy as np\n",
    "\n",
    "# IDM-VTON category mapping: Lookzi → IDM\n",
    "CATEGORY_MAP = {\n",
    "    'upper': 'upper_body',\n",
    "    'lower': 'lower_body',\n",
    "    'overall': 'dresses',\n",
    "}\n",
    "\n",
    "def run_idm_vton(person_path, garment_path, cloth_type, n_steps=20, scale=2.0, seed=42):\n",
    "    \"\"\"IDM-VTON'ni bitta juft uchun ishga tushiradi.\"\"\"\n",
    "    person_img = Image.open(person_path).convert('RGB')\n",
    "    garment_img = Image.open(garment_path).convert('RGB')\n",
    "    category = CATEGORY_MAP.get(cloth_type, 'upper_body')\n",
    "\n",
    "    try:\n",
    "        # Gradio demo pipeline orqali\n",
    "        result, mask = start_tryon(\n",
    "            {\"background\": person_img, \"layers\": [], \"composite\": None},\n",
    "            garment_img,\n",
    "            garment_des=\"\",\n",
    "            is_checked=True,       # auto mask\n",
    "            is_checked_crop=False,\n",
    "            denoise_steps=n_steps,\n",
    "            seed=seed,\n",
    "        )\n",
    "        return result\n",
    "    except Exception as e:\n",
    "        print(f\"  Xato: {e}\")\n",
    "        return None\n",
    "\n",
    "def show_comparison(person_path, garment_path, catvton_result_path, idm_result, pair_id, tag):\n",
    "    \"\"\"Person | Garment | CatVTON | IDM-VTON yonma-yon ko'rsatish.\"\"\"\n",
    "    from IPython.display import display\n",
    "    import matplotlib.pyplot as plt\n",
    "    import matplotlib.patches as mpatches\n",
    "\n",
    "    person = Image.open(person_path).convert('RGB').resize((256, 384))\n",
    "    garment = Image.open(garment_path).convert('RGB').resize((256, 384))\n",
    "\n",
    "    has_catvton = catvton_result_path and os.path.exists(catvton_result_path)\n",
    "    catvton = Image.open(catvton_result_path).convert('RGB').resize((256, 384)) if has_catvton else None\n",
    "    idm = idm_result.resize((256, 384)) if idm_result else None\n",
    "\n",
    "    n_cols = 2 + (1 if catvton else 0) + (1 if idm else 0)\n",
    "    fig, axes = plt.subplots(1, n_cols, figsize=(n_cols * 3.5, 6))\n",
    "    fig.suptitle(f\"{pair_id} — {tag}\", fontsize=13, fontweight='bold')\n",
    "\n",
    "    col = 0\n",
    "    for ax, img, title in [\n",
    "        (axes[col], person, \"Person\"),\n",
    "        (axes[col+1], garment, \"Garment\"),\n",
    "    ]:\n",
    "        ax.imshow(img); ax.set_title(title); ax.axis('off')\n",
    "    col += 2\n",
    "\n",
    "    if catvton:\n",
    "        axes[col].imshow(catvton); axes[col].set_title(\"CatVTON\"); axes[col].axis('off')\n",
    "        col += 1\n",
    "    if idm:\n",
    "        axes[col].imshow(idm); axes[col].set_title(\"IDM-VTON\"); axes[col].axis('off')\n",
    "\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "\n",
    "print(\"Funksiyalar tayyor.\")"
   ]
  },
  {
