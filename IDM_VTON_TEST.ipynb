   "source": [
    "# Cell 9 — Agar CatVTON natijalarini ham qo'shmoqchi bo'lsangiz\n",
    "# (Bu cell ixtiyoriy — CatVTON natijalarini bu yerga yuklab taqqoslay olasiz)\n",
    "\n",
    "# Lookzi app'dan render qilingan natijani Drive'ga saqlash:\n",
    "# resource/demo/output/ papkasidan kerakli rasmni quyidagicha nomlab Drive'ga ko'chiring:\n",
    "# C01_catvton.png, C04_catvton.png va h.k.\n",
    "\n",
    "# Keyin quyidagi kod taqqoslashni qayta ko'rsatadi:\n",
    "OUTPUT_DIR = \"/content/drive/MyDrive/Lookzi/idm_test_results\"\n",
    "LOOKZI_ROOT = \"/content/Lookzi\"\n",
    "import json, os\n",
    "from PIL import Image\n",
    "\n",
    "with open(f\"{LOOKZI_ROOT}/benchmark/catalog_pairs.json\") as f:\n",
    "    pairs = json.load(f)[\"pairs\"]\n",
    "\n",
    "for pair in pairs:\n",
    "    pid = pair[\"id\"]\n",
    "    catvton_path = f\"{OUTPUT_DIR}/{pid}_catvton.png\"\n",
    "    idm_path = f\"{OUTPUT_DIR}/{pid}_idm.png\"\n",
    "    if not os.path.exists(idm_path):\n",
    "        continue\n",
    "    idm_result = Image.open(idm_path)\n",
    "    show_comparison(\n",
    "        f\"{LOOKZI_ROOT}/{pair['person']}\",\n",
    "        f\"{LOOKZI_ROOT}/{pair['garment']}\",\n",
    "        catvton_path if os.path.exists(catvton_path) else None,\n",
    "        idm_result,\n",
    "        pid, pair['tag']\n",
    "    )"
   ]
  }
 ]
}"
